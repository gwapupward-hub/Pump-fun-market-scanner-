# Copy to .env and adjust. See README for full variable list.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/pump_intel
PUMP_INGEST_SOURCE=http
PUMP_INGEST_FIXTURE_PATH=fixtures/sample_coins.json
PUMP_API_BASE=https://frontend-api-v3.pump.fun
# PUMP_API_BEARER=
PUMP_SCAN_COIN_LIMIT=200
AI_SUMMARY_ENABLED=true
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LOG_LEVEL=INFO
