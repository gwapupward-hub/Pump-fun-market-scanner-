# --- Required for docker-compose ---
POSTGRES_USER=pump
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=pump_intel

# --- Required for the app ---
# Local-Python form (host -> localhost):
DATABASE_URL=postgresql://pump:change-me-please@localhost:5432/pump_intel

# --- Pump API ---
PUMP_API_BASE=https://frontend-api-v3.pump.fun
PUMP_ORIGIN=https://pump.fun

# --- Ingestion tuning ---
INGEST_PAGE_SIZE=100
INGEST_MAX_PAGES=30

# --- Snapshot dedup / retention ---
SNAPSHOT_STALE_SECONDS=86400
SNAPSHOT_RETENTION_DAYS=90
HOLDER_RETENTION_DAYS=180
REPORT_RETENTION_DAYS=365

# --- Optional Solana JSON-RPC (recommended: paid provider) ---
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# SOLANA_RPC_CONCURRENCY=4
# HOLDER_ENRICHMENT_TOP_N=500

# --- HTTP retry policy ---
HTTP_RETRY_ATTEMPTS=3
HTTP_RETRY_BASE_DELAY_S=0.5

# --- Optional OpenAI-compatible LLM ---
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# --- Observability ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Scheduler (UTC) ---
SCHEDULER_CRON_HOUR=0
SCHEDULER_CRON_MINUTE=7

# --- Healthcheck thresholds ---
HEALTHCHECK_MAX_AGE_HOURS=36
